# Copy to .env and fill in. NEVER commit .env (it holds your private key).
# Testnet only — see CLAUDE.md guardrails. Do not deploy to mainnet.

# Deployer key for a FUNDED Base Sepolia test wallet (0x-prefixed).
# Use a throwaway key, never a wallet holding real funds.
PRIVATE_KEY=0x

# Base Sepolia RPC endpoint (e.g. https://sepolia.base.org or an Alchemy/Infura URL)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional: BaseScan API key for contract verification on deploy
ETHERSCAN_API_KEY=
