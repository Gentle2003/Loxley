# Copy to .env and fill in. NEVER commit .env (it holds your private key).
# Testnet only — see CLAUDE.md guardrails. Do not deploy to mainnet.

# Deployer key for a FUNDED Robinhood Chain testnet wallet (0x-prefixed).
# Use a throwaway key, never a wallet holding real funds.
PRIVATE_KEY=0x

# Robinhood Chain testnet — chain ID 46630, native gas token ETH.
# Docs: https://docs.robinhood.com/chain/
RH_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com

# Optional: Blockscout API key for contract verification (usually not required).
BLOCKSCOUT_API_KEY=

# --- Frontend (Vite) ---
# Deployed Sherwood registry address. Setting this flips the app from mock mode
# to LIVE (real viem reads/writes on RH testnet). Empty = mock design build.
VITE_SHERWOOD_ADDRESS=

# Optional override for the RH testnet RPC the frontend reads from.
VITE_RH_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com
