# Copy to .env and fill in. NEVER commit .env (it holds your private key).
# Testnet only — see CLAUDE.md guardrails. Do not deploy to mainnet.

# Deployer key for a FUNDED Robinhood Chain testnet wallet (0x-prefixed).
# Use a throwaway key, never a wallet holding real funds.
PRIVATE_KEY=0x

# Robinhood Chain testnet — chain ID 46630, native gas token ETH.
# Docs: https://docs.robinhood.com/chain/
RH_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com

# Optional: Blockscout API key for contract verification (usually not required).
BLOCKSCOUT_API_KEY=

# --- Frontend (Vite) ---
# Deployed Sherwood registry address. Setting this flips the app from mock mode
# to LIVE (real viem reads/writes on RH testnet). Empty = mock design build.
VITE_SHERWOOD_ADDRESS=

# Network target (frontend). Defaults to RH testnet (46630). To point at a local
# mainnet fork or real mainnet, set these (trading via Uniswap needs chain 4663):
#   VITE_CHAIN_ID=4663
#   VITE_CHAIN_RPC=http://127.0.0.1:8545     (fork)  |  https://rpc.mainnet.chain.robinhood.com
VITE_CHAIN_ID=46630
VITE_CHAIN_RPC=https://rpc.testnet.chain.robinhood.com
VITE_CHAIN_EXPLORER=https://explorer.testnet.chain.robinhood.com

# Trading runs through Uniswap V2 (already deployed on RH Chain) — no custom AMM.
# Uniswap only exists on mainnet (4663), so on testnet the market UI shows
# "trading launches on mainnet"; register/tribute/bounty still work on testnet.

# Footer display: the contract address to show (falls back to the registry
# address), the X/socials URL, and the network label.
VITE_CONTRACT_ADDRESS=
VITE_X_URL=https://x.com/Loxleyrobinhood
VITE_NETWORK_LABEL=Robinhood Chain testnet

# --- GitHub OAuth ownership verification (optional) — see OAUTH.md ---
# Proves a registrant has ADMIN rights on the repo before they can register it.
# Unset = MOCK mode (verification resolves "verified" with no redirect), so the
# flow is demoable before you create the OAuth App.
#
# Frontend (public — safe to expose): the OAuth App client id.
VITE_GITHUB_CLIENT_ID=
# Optional OAuth scope. "" = public repos only; set "repo" to also cover private.
# VITE_GITHUB_SCOPE=
#
# Serverless only (SECRET — never prefix with VITE_, never commit real values):
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Force the /api/verify-repo mock even with an id set (local dev):
# VERIFY_MOCK=1
#
# GitHub read proxy (api/gh) — lifts GitHub reads from 60 req/hr (browser,
# unauthenticated, per-IP) to 5,000 req/hr. Fine-grained PAT, READ-ONLY, public
# repos, no write scope. Server-only — do NOT prefix with VITE_. Absent = the
# proxy still runs + caches, just unauthenticated.
# GITHUB_TOKEN=
#
# Verified ✓ badge persistence — a KV store so OAuth-verified repos are badged
# for every visitor. Provisioning Vercel KV (or Upstash Redis) auto-injects
# these; the code reads either naming pair. Unset = badge falls back to the
# loxley-verify.txt proof only. Server-only — do NOT prefix with VITE_.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
